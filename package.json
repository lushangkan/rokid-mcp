{
  "name": "rokid-mcp",
  "private": true,
  "packageManager": "bun@1.2.5",
  "workspaces": [
    "apps/android",
    "apps/relay-server",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "build:android": "apps/android/gradlew -p apps/android :phone-app:assembleDebug :glasses-app:assembleDebug",
    "build:android:glasses": "apps/android/gradlew -p apps/android :glasses-app:assembleDebug",
    "build:android:phone": "apps/android/gradlew -p apps/android :phone-app:assembleDebug",
    "typecheck": "tsc -b --pretty false",
    "dev:relay": "bun run --cwd apps/relay-server dev"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
